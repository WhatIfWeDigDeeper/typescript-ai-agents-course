{
  "name": "typescript-ai-agents-tutorial",
  "version": "1.0.0",
  "description": "Modern TypeScript AI Agents Tutorial - Learn to build AI agents from scratch",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "module1:prompting": "ts-node src/module1/ProgrammaticPrompting.ts",
    "module1:quasi": "ts-node src/module1/QuasiAgent.ts",
    "module1:agent": "ts-node src/module1/AgentLoop.ts",
    "module2:function-calling": "ts-node src/module2/FunctionCallingExample.ts",
    "module2:agent": "ts-node src/module2/AgentLoopFunctionCalling.ts",
    "module3:game": "ts-node src/module3/GAMEAgent.ts",
    "module3:readme": "ts-node src/module3/ReadmeCreatorAgent.ts",
    "module4:self-prompting": "ts-node src/module4/SelfPromptingAgent.ts"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "openai",
    "typescript",
    "tutorial"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "openai": "^6.16.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
