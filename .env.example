# =============================================================================
# AI Agents Tutorial - Environment Configuration
# =============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env:    cp .env.example .env
# 2. Fill in your OpenAI API key below
# 3. Run any module:            npm run module1:prompting
#
# =============================================================================

# Your OpenAI API key (required)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Override the default model (defaults to gpt-4)
# Options: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# OPENAI_MODEL=gpt-4

# Optional: Enable debug logging
# DEBUG=true
